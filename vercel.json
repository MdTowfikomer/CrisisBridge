{
  "name": "crisisbridge-frontend",
  "buildCommand": "pnpm --filter web... build",
  "outputDirectory": "apps/web/dist",
  "installCommand": "pnpm install",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/(api|triage|acknowledge|resolve|audit|map|floorplan|b2b)/(.*)",
      "destination": "https://crisisbridge-server.onrender.com/$1/$2"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
