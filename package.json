{
  "name": "crisisbridge",
  "private": true,
  "packageManager": "pnpm@10.15.1",
  "engines": {
    "node": "20.x",
    "pnpm": ">=10.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@firebase/util",
      "protobufjs"
    ]
  },
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:web": "pnpm --filter web dev",
    "dev:server": "pnpm --filter server dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "turbo": "latest",
    "vitest": "^1.6.0"
  },
  "type": "module"
}
