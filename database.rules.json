{
  "rules": {
    "properties": {
      "$propertyId": {
        ".read": "true",
        "activeMode": {
          ".write": "auth != null"
        },
        "missionProfiles": {
          ".read": "true",
          ".write": "auth != null"
        }
      }
    },
    "maps": {
      "$propertyId": {
        ".read": "true",
        ".write": "auth != null"
      }
    },
    "alerts": {
      ".read": "true",
      ".write": "true",
      ".indexOn": ["status"]
    },
    "tracking": {
      "$propertyId": {
        "$userId": {
          ".read": "true",
          ".write": "true"
        }
      }
    },
    "broadcasts": {
      ".read": "true",
      ".write": "auth != null"
    },
    "broadcast_acks": {
      ".read": "true",
      ".write": "true"
    },
    "users": {
      ".read": "auth != null",
      ".write": "auth != null"
    }
  }
}